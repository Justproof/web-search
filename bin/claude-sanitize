#!/usr/bin/env bun
// claude-sanitize — stdin → sanitise() → stdout
//
// Subcommands:
//   (default)        Read stdin, write wrapped sanitised output to stdout.
//                    Used by the Bash command rewrite path (FR-4).
//                    Args: --url=<url>  (required)
//   replay --since DATE [--version VERSION]
//                    Re-run the current rule set against historical fetch_log
//                    entries; report drift (FR-27).

import { sanitise, wrap, SANITISER_VERSION } from "../hooks/lib/sanitise.ts";
import {
    computeSignals,
    computeSimhash,
    loadRiskTiersConfig,
    partitionByTier,
} from "../hooks/lib/signals.ts";
import { ensureStateDir, getDb } from "../hooks/lib/state.ts";

const argv = process.argv.slice(2);

const parseArgs = (args: string[]): Map<string, string> => {
    const out = new Map<string, string>();
    for (const a of args) {
        const m = /^--([^=]+)=(.*)$/.exec(a);
        if (m) {
            out.set(m[1]!, m[2]!);
        } else if (a.startsWith("--")) {
            out.set(a.slice(2), "true");
        }
    }
    return out;
};

const sanitiseStdin = async (urlHint: string): Promise<void> => {
    const stdin = await Bun.stdin.text();
    const result = sanitise(stdin);
    const cfg = loadRiskTiersConfig();
    const sessionId = process.env.CLAUDE_SESSION_ID ?? null;
    const domain = (() => {
        try {
            return new URL(urlHint).hostname.toLowerCase();
        } catch {
            return urlHint;
        }
    })();
    const signals = computeSignals({
        url: urlHint,
        domain,
        body: stdin,
        contentTypeHeader: null,
        redirectHops: 0,
        zeroWidthCount: result.zeroWidthCount,
        strippedBytes: result.strippedBytes,
        originalBytes: result.originalBytes,
        simhash: computeSimhash(result.sanitised),
        sessionId,
        cfg,
    });
    const wrapped = wrap({
        url: urlHint,
        riskSignals: signals.fired,
        result,
    });
    process.stdout.write(wrapped);
};

const replay = async (args: Map<string, string>): Promise<void> => {
    const since = args.get("since");
    if (!since) {
        process.stderr.write(
            "usage: claude-sanitize replay --since=YYYY-MM-DD [--version=X]\n",
        );
        process.exit(2);
    }
    const versionFilter = args.get("version") ?? null;
    const db = getDb();
    const rows = db
        .prepare(
            `SELECT id, url, domain, fetched_at, content_sha256, risk_signals, sanitiser_version
       FROM fetch_log WHERE fetched_at >= ? ORDER BY fetched_at ASC`,
        )
        .all(since) as {
        id: number;
        url: string;
        domain: string;
        fetched_at: string;
        content_sha256: string | null;
        risk_signals: string;
        sanitiser_version: string;
    }[];

    let wouldFireNow = 0;
    let usedToFireOnly = 0;
    let unchanged = 0;
    const newSignalCounts = new Map<string, number>();
    const oldSignalCounts = new Map<string, number>();

    const cfg = loadRiskTiersConfig();
    for (const row of rows) {
        if (versionFilter && row.sanitiser_version !== versionFilter) {
            continue;
        }
        const oldSignals = row.risk_signals
            ? row.risk_signals.split(",").filter(Boolean)
            : [];
        const oldTiers = partitionByTier(oldSignals, cfg);

        for (const s of oldSignals) {
            oldSignalCounts.set(s, (oldSignalCounts.get(s) ?? 0) + 1);
        }
        for (const s of oldSignals) {
            const def = cfg.signals[s];
            if (!def) {
                continue;
            }
            newSignalCounts.set(s, (newSignalCounts.get(s) ?? 0) + 1);
        }
        const wouldAbortNow =
            oldTiers.critical.length > 0 ||
            oldTiers.elevated.length >= cfg.thresholds.abort_on_elevated_count;
        const wouldHaveAborted =
            oldTiers.critical.length > 0 ||
            oldTiers.elevated.length >= cfg.thresholds.abort_on_elevated_count;
        if (wouldAbortNow && !wouldHaveAborted) {
            wouldFireNow++;
        } else if (!wouldAbortNow && wouldHaveAborted) {
            usedToFireOnly++;
        } else {
            unchanged++;
        }
    }

    process.stdout.write(
        JSON.stringify(
            {
                since,
                version_filter: versionFilter,
                rows_examined: rows.length,
                sanitiser_version_now: SANITISER_VERSION,
                drift: {
                    would_abort_now_only: wouldFireNow,
                    used_to_abort_only: usedToFireOnly,
                    unchanged,
                },
                signal_counts_old: Object.fromEntries(oldSignalCounts),
                signal_counts_new: Object.fromEntries(newSignalCounts),
                note: "Tier-reclassification drift only; full body re-sanitisation requires CLAUDE_SANITISER_DEBUG=1 captures or on-demand refetch.",
            },
            null,
            2,
        ) + "\n",
    );
};

const main = async (): Promise<void> => {
    ensureStateDir();
    const sub = argv[0];
    if (sub === "replay") {
        await replay(parseArgs(argv.slice(1)));
        return;
    }
    if (sub === "status") {
        const db = getDb();
        const total = db
            .prepare("SELECT COUNT(*) AS n FROM fetch_log")
            .get() as {
            n: number;
        };
        const blocklistCount = db
            .prepare("SELECT COUNT(*) AS n FROM blocklist")
            .get() as { n: number };
        const sessionCount = db
            .prepare("SELECT COUNT(*) AS n FROM sessions")
            .get() as { n: number };
        process.stdout.write(
            JSON.stringify(
                {
                    sanitiser_version: SANITISER_VERSION,
                    mode: process.env.CLAUDE_SANITISER_MODE ?? "log",
                    fetch_log_rows: total.n,
                    blocklist_size: blocklistCount.n,
                    sessions: sessionCount.n,
                },
                null,
                2,
            ) + "\n",
        );
        return;
    }
    const args = parseArgs(argv);
    const url = args.get("url") ?? "stdin";
    await sanitiseStdin(url);
};

main().catch((err) => {
    process.stderr.write(`claude-sanitize error: ${(err as Error).message}\n`);
    process.exit(1);
});
